# Maisha API (NestJS) — copy to .env and edit. In production set strong secrets or boot is refused.

# HTTP
PORT=8000

# Environment: "production" refuses the shipped default secrets below.
MAISHA_ENVIRONMENT=development

# Database. Postgres in prod (URL starting with postgres://). Omit for local SQLite.
# MAISHA_DATABASE_URL=postgres://maisha:maisha@localhost:5432/maisha
MAISHA_DATABASE_FILE=./data/maisha-nest.db
# Set false in prod to disable schema auto-sync (migrations own the schema). Postgres forces off.
MAISHA_DB_SYNC=true

# Mahsa (Rust) sidecar — the validation authority. App fails loud if it is unreachable.
MAISHA_MAHSA_URL=http://127.0.0.1:8088
MAISHA_MAHSA_TIMEOUT_MS=5000

# Single-user auth (CHANGE BOTH IN PRODUCTION).
MAISHA_APP_PASSWORD=change-me
MAISHA_SESSION_SECRET=dev-insecure-session-secret-change-me
MAISHA_SECURE_COOKIES=false

# Audit / actor
MAISHA_DEFAULT_USER_ID=founder

# OCR (receipt parsing). tesseract = local CLI (zero infra); paddle = PaddleOCR sidecar (best
# accuracy for Indian receipts/invoices/tables — start the `ocr` docker-compose profile).
MAISHA_OCR_PROVIDER=tesseract
MAISHA_OCR_URL=http://127.0.0.1:8090

# Scheduler (PRD Layer 6). When enabled, runs daily capture + CFO brief + alerts + dunning at
# the local wall-clock time below. Enable on ONE replica only (each fires the jobs).
MAISHA_SCHEDULER_ENABLED=false
MAISHA_BRIEF_HOUR=20
MAISHA_BRIEF_MINUTE=0
MAISHA_BRIEF_TZ=Asia/Kolkata

# Email channel. InMemory (dry-run) unless SMTP is enabled. Point at MailHog locally / SMTP relay in prod.
MAISHA_SMTP_ENABLED=false
MAISHA_SMTP_HOST=127.0.0.1
MAISHA_SMTP_PORT=1025
MAISHA_SMTP_USERNAME=
MAISHA_SMTP_PASSWORD=
MAISHA_SMTP_USE_TLS=false
MAISHA_EMAIL_SENDER=cfo@maisha-mahsa.local
MAISHA_CFO_EMAIL=founder@maisha-mahsa.local
MAISHA_APP_NAME=Maisha-Mahsa
