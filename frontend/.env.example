# Frontend (React SPA) build configuration — Vite reads these at BUILD time and bakes them into
# the bundle (import.meta.env.*). Copy to .env.production (or .env.local for dev) before
# `npm run build`. Changing them later requires a rebuild.

VITE_API_BASE=
# Base URL of the Maisha API (src/lib/api.ts, src/routes/Onboarding.tsx).
# Empty = same-origin "/api/..." — correct when the SPA is served under the same domain as the
# API (e.g. behind the same Caddy). Set https://your-api-domain when hosted separately.
# Dev: also used by vite.config.ts as the dev-server proxy target (default http://localhost:8000).

VITE_BETTER_AUTH_URL=
# Base URL of YOUR Better Auth deployment (src/lib/auth.ts — the official better-auth/react
# client points here for sign-in, org selection, 2FA and GET /api/auth/token).
# REQUIRED for any authenticated flow; empty = same-origin (only correct if Better Auth is
# reverse-proxied under the same domain). Must match the API's MAISHA_BETTER_AUTH_URL semantics:
# the JWT this server issues is what the API verifies via {URL}/api/auth/jwks.
