# ══════════════════════════════════════════════════════════════════════════════════════════════
# Maisha-Mahsa — MASTER environment reference (launch pack)
# ══════════════════════════════════════════════════════════════════════════════════════════════
# Every environment variable any part of this repo reads, verified against the code:
#   · api/app/config.py           (pydantic Settings, prefix MAISHA_, reads .env in api/ CWD)
#   · api/app/core/betterauth.py  (MAISHA_BETTER_AUTH_*)
#   · api/app/core/entitlement_deps.py (MAISHA_BETTER_AUTH_PLAN_CLAIM)
#   · dif/src/main.rs             (MAHSA_ADDR, MAHSA_RULES)
#   · frontend/src/lib/{api,auth}.ts + vite.config.ts (VITE_API_BASE, VITE_BETTER_AUTH_URL)
#   · infra/docker-compose*.yml + Caddyfile (MAISHA_DOMAIN, pass-throughs)
#   · infra/backup/*.sh           (RESTIC_*, MAISHA_DATA_DIR)
#   · scripts/rls_redteam.sh      (PG_PSQL, PG_CONTAINER, PGUSER)
#   · scripts/ci_gate.sh          (CI, REQUIRE_REDTEAM)
#   · api/tests/                  (MAISHA_TEST_POSTGRES_URL — test-only)
#
# WHICH FILE GOES WHERE:
#   · Local dev (uvicorn from api/):     copy api/.env.example  → api/.env
#   · Docker prod stack (infra/):        copy api/.env.example  → infra/.env
#   · Frontend build:                    copy frontend/.env.example → frontend/.env.production
# This file is the reference; the two smaller ones are what you actually copy.
#
# Legend:  [PROD-REQUIRED] must be set for production;  [dev default OK] safe to leave alone.

# ── Core API (pydantic Settings — api/app/config.py) ──────────────────────────────────────────
MAISHA_ENVIRONMENT=development
#   [PROD-REQUIRED] Set "production" on the server. In production the app REFUSES to boot
#   without MAISHA_BETTER_AUTH_URL or with the default MAISHA_SESSION_SECRET (app/main.py
#   create_app). Better Auth JWTs are the ONLY way in — the legacy HMAC password login is
#   deleted (P2-6): SPA sends the JWT as a bearer header, HTMX pages carry the same JWT in
#   the `maisha_jwt` cookie.

MAISHA_DATABASE_URL=sqlite:///./data/maisha.db
#   [PROD-REQUIRED] SQLAlchemy URL. Dev default = local SQLite file.
#   Postgres/Supabase (the multi-tenant launch path):
#     postgresql://USER:PASSWORD@HOST:5432/postgres?options=-csearch_path%3Dtenant_core,public
#   · the search_path option is REQUIRED on Postgres — the multi-tenant tables live in the
#     tenant_core schema (alembic 0002_multitenant_core), and app/jobs.py documents exactly this
#     URL shape.
#   · Use a SESSION-mode connection (Supabase: direct port 5432 or the session pooler), NOT the
#     transaction pooler (6543): RLS depends on a session GUC re-bound on every SQLAlchemy pool
#     checkout (app/core/principal.py SET_ORG_GUC_SQL, set_config(..., false) = session-scoped);
#     transaction pooling reassigns server connections mid-session and breaks that binding.
#   · Postgres needs the psycopg2 driver: pip install -e "api[pg]" (see api/pyproject.toml).

MAISHA_MAHSA_URL=http://127.0.0.1:8088
#   [PROD-REQUIRED] Base URL of the Mahsa (Rust) recomputation sidecar. Docker: http://dif:8088.
#   Every ✓ Verified figure exists because the API reached this engine — if it is wrong the app
#   degrades to honest-pending, never fabricates.

# ── Auth ──────────────────────────────────────────────────────────────────────────────────────
MAISHA_BETTER_AUTH_URL=
#   [PROD-REQUIRED] Base URL of YOUR Better Auth deployment (the TypeScript auth layer the owner
#   runs — this repo only VERIFIES its JWTs via {URL}/api/auth/jwks; api/app/core/betterauth.py).
#   Unset ⇒ every bearer request 401s. See docs/DEPLOYMENT.md §4 for the required jwt
#   definePayload (activeOrganizationId + role + email claims).
MAISHA_BETTER_AUTH_ISSUER=
#   Optional. JWT `iss` to enforce; defaults to MAISHA_BETTER_AUTH_URL (Better Auth's default).
MAISHA_BETTER_AUTH_AUDIENCE=
#   Optional. JWT `aud` to enforce; defaults to MAISHA_BETTER_AUTH_URL.
MAISHA_BETTER_AUTH_MFA_CLAIM=
#   Optional. Name of a boolean JWT claim asserting 2FA was completed. UNSET = MFA not enforced
#   by the API (documented behaviour in betterauth.py — set it only once Better Auth actually
#   emits the claim, or every Owner/Admin/Approver request is denied).
MAISHA_BETTER_AUTH_PLAN_CLAIM=
#   Optional. JWT claim carrying the org's entitlement plan (default claim name: "plan").
MAISHA_SIGNIN_URL=/sign-in
#   Where an unauthenticated BROWSER page-load is redirected (the SPA's Better Auth sign-in
#   route). Set an absolute URL when the frontend is served from a different origin.

MAISHA_SESSION_SECRET=dev-insecure-session-secret-change-me
#   [PROD-REQUIRED to be non-default] HMAC key for action preview tokens
#   (api/app/web/api_actions.py). No longer signs any auth cookie (P2-6).
#   Generate: python3 -c "import secrets; print(secrets.token_hex(32))"

# ── Company / filings ─────────────────────────────────────────────────────────────────────────
MAISHA_COMPANY_GSTIN=
#   Filer GSTIN for GSTR-1 JSON export / e-invoice payloads. Empty = exports carry no GSTIN.
MAISHA_GST_FILING_PROFILE=monthly
#   GST filing profile for the WS1.D2 obligation calendar: monthly | qrmp | composition.
MAISHA_DEFAULT_USER_ID=founder
#   Audit-entry author for legacy (non-JWT) dev flows. [dev default OK]

# ── Email (statutory alerts, CFO brief, dunning, investor updates) ────────────────────────────
MAISHA_CFO_EMAIL=founder@maisha-mahsa.local
#   [PROD-REQUIRED] Where the daily CFO brief + alerts are delivered.
MAISHA_EMAIL_SENDER=cfo@maisha-mahsa.local
#   [PROD-REQUIRED] From-address on outbound mail.
MAISHA_SMTP_HOST=127.0.0.1
#   [PROD-REQUIRED] Dev default targets local MailHog (make dev). Prod: your SMTP relay.
MAISHA_SMTP_PORT=1025
MAISHA_SMTP_USERNAME=
MAISHA_SMTP_PASSWORD=
MAISHA_SMTP_USE_TLS=false
#   true for a TLS relay (e.g. port 465).

# ── Incident alerting (WS10.2 CERT-In posture) ────────────────────────────────────────────────
MAISHA_ALERT_WEBHOOK_URL=
#   [PROD-REQUIRED] Severity events (unhandled 5xx) POST JSON {source,event,severity,detail,at}
#   here — a Slack/Discord incoming webhook or alertmanager receiver a human actually sees.
#   Empty = local ERROR log only (dev). docs/DEPLOYMENT.md §10.

# ── LLM drafting layer (OPTIONAL — Mahsa recomputes every number regardless) ──────────────────
MAISHA_LLM_PROVIDER=off
#   off | ollama | claude. "off" keeps run_loop fully deterministic. [dev default OK]
MAISHA_OLLAMA_URL=http://127.0.0.1:11434
MAISHA_OLLAMA_MODEL=qwen3:14b
MAISHA_CLAUDE_MODEL=claude-opus-4-8
MAISHA_CLAUDE_API_KEY=
#   OWNER-STEP if provider=claude: Anthropic API key from console.anthropic.com.
MAISHA_CLAUDE_BASE_URL=https://api.anthropic.com
MAISHA_LLM_TEMPERATURE=0.0
MAISHA_LLM_TIMEOUT_S=30.0
MAISHA_LLM_MAX_RETRIES=2

# ── Scheduler (daily snapshot capture + 8pm CFO brief; app/jobs.py) ───────────────────────────
MAISHA_BRIEF_HOUR=20
MAISHA_BRIEF_MINUTE=0
MAISHA_BRIEF_TZ=Asia/Kolkata

# ── Cosmetic (rarely set; pydantic reads them like any Settings field) ────────────────────────
#MAISHA_APP_NAME=Maisha-Mahsa
#MAISHA_VERSION=4.0.0

# ── Reverse proxy (infra/docker-compose.prod.yml + infra/Caddyfile) ───────────────────────────
MAISHA_DOMAIN=
#   [PROD-REQUIRED for the Caddy stack] Your domain. Caddy auto-provisions Let's Encrypt TLS
#   for it and reverse-proxies to api:8000. Compose refuses to start caddy without it.

# ── Mahsa sidecar (dif/src/main.rs — only when running the binary yourself) ───────────────────
#MAHSA_ADDR=0.0.0.0:8088
#   Listen address. Docker images set this already. [dev default OK]
#MAHSA_RULES=
#   Path to an external rules.yaml. UNSET = the embedded, tested rule set (recommended).
#MAHSA_RULES_MANIFEST=
#   REQUIRED whenever MAHSA_RULES is set: path to the pack's MANIFEST.yaml (version + sha256).
#   Mahsa refuses to boot with a file pack that has no verified manifest — docs/RULE_PACK_SLA.md.

# ── Frontend build (frontend/.env.example — Vite, baked in at BUILD time) ─────────────────────
#VITE_API_BASE=
#VITE_BETTER_AUTH_URL=

# ── Backups (infra/backup/*.sh — run on the host, NOT read by the app) ────────────────────────
#RESTIC_REPOSITORY=          # [PROD-REQUIRED for backups] e.g. s3:s3.amazonaws.com/bucket/maisha
#RESTIC_PASSWORD=            # [PROD-REQUIRED for backups] repo encryption password — keep out of git
#MAISHA_DATA_DIR=            # default /var/lib/docker/volumes/maisha_data/_data
#RESTIC_KEEP_DAILY=7
#RESTIC_KEEP_WEEKLY=4
#RESTIC_KEEP_MONTHLY=6

# ── CI / verification scripts (never needed in production runtime) ────────────────────────────
#PG_PSQL=                    # scripts/rls_redteam.sh: psql command for the live RLS red-team,
#                            #   e.g. "psql -U postgres -h 127.0.0.1". Needs CREATEDB — it makes
#                            #   and drops a throwaway ws4_rls_test database. NEVER point it at
#                            #   your production database.
#PG_CONTAINER=api-nest-db-1  # alt: a docker postgres container name for the red-team
#PGUSER=maisha               # user for that container
#REQUIRE_REDTEAM=            # ci_gate.sh: "1" makes a skipped red-team a FAILURE (CI sets CI=true)
#MAISHA_TEST_POSTGRES_URL=   # tests only: enables the Postgres leg of test_import_roundtrip
