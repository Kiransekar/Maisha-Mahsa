# Maisha-Mahsa configuration (copy to api/.env for local dev, or to infra/.env for the Docker
# stack; all app keys are prefixed MAISHA_). Full per-variable reference: /.env.example at the
# repo root. In production set MAISHA_ENVIRONMENT=production — the app then refuses to boot with
# the default password or session secret below, and legacy password login turns HARD OFF.

# --- Core ---
MAISHA_ENVIRONMENT=development          # set to "production" on the VPS
MAISHA_DOMAIN=maisha.example.com        # your domain (Caddy auto-provisions TLS for it)
MAISHA_MAHSA_URL=http://127.0.0.1:8088  # Mahsa sidecar; http://dif:8088 inside Docker
MAISHA_DATABASE_URL=sqlite:///./data/maisha.db
# Postgres/Supabase (multi-tenant launch path — needs `pip install -e "api[pg]"`; use a
# SESSION-mode connection, NOT the transaction pooler — see /.env.example for why):
#MAISHA_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?options=-csearch_path%3Dtenant_core,public

# --- Auth (REQUIRED in production) ---
# Better Auth (the TypeScript auth layer YOU deploy; this API only verifies its JWTs via JWKS).
# REQUIRED in production — without it no bearer request can authenticate. docs/DEPLOYMENT.md §4.
MAISHA_BETTER_AUTH_URL=
MAISHA_BETTER_AUTH_ISSUER=              # optional; defaults to MAISHA_BETTER_AUTH_URL
MAISHA_BETTER_AUTH_AUDIENCE=            # optional; defaults to MAISHA_BETTER_AUTH_URL
MAISHA_BETTER_AUTH_MFA_CLAIM=           # optional; unset = MFA not enforced by the API
MAISHA_BETTER_AUTH_PLAN_CLAIM=          # optional; JWT claim for the org's plan (default "plan")
MAISHA_SIGNIN_URL=/sign-in              # where unauthenticated browsers are redirected (SPA route)
# P2-6: the legacy password login is DELETED — auth is Better Auth JWT only (header or
# `maisha_jwt` cookie). MAISHA_SESSION_SECRET now only signs action preview tokens.
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
MAISHA_SESSION_SECRET=dev-insecure-session-secret-change-me

# --- Company / filings ---
MAISHA_COMPANY_GSTIN=                   # your GSTIN, for GSTR-1 / e-invoice exports
MAISHA_DEFAULT_USER_ID=founder          # audit author for legacy (non-JWT) dev flows

# --- Email (statutory alerts, CFO brief, investor updates) ---
MAISHA_CFO_EMAIL=founder@example.com
MAISHA_EMAIL_SENDER=cfo@example.com
MAISHA_SMTP_HOST=127.0.0.1
MAISHA_SMTP_PORT=1025                   # 1025 = local MailHog; use your SMTP relay in prod
MAISHA_SMTP_USERNAME=                   # set for an authenticated production relay
MAISHA_SMTP_PASSWORD=
MAISHA_SMTP_USE_TLS=false               # true for a TLS relay (e.g. port 465)

# --- Incident alerting (WS10.2 CERT-In posture) ---
MAISHA_ALERT_WEBHOOK_URL=               # severity events POST JSON here (Slack/Discord/
                                        # alertmanager webhook); empty = local ERROR log only.
                                        # OWNER-STEP before GA — docs/DEPLOYMENT.md §10

# --- LLM drafting layer (optional; every number is still recomputed by Mahsa) ---
MAISHA_LLM_PROVIDER=off                 # off | ollama | claude
MAISHA_OLLAMA_URL=http://127.0.0.1:11434
MAISHA_OLLAMA_MODEL=qwen3:14b
MAISHA_CLAUDE_MODEL=claude-opus-4-8
MAISHA_CLAUDE_API_KEY=                  # OWNER-STEP if provider=claude (console.anthropic.com)
MAISHA_CLAUDE_BASE_URL=https://api.anthropic.com
MAISHA_LLM_TEMPERATURE=0.0              # determinism (paired with the eval gate)
MAISHA_LLM_TIMEOUT_S=30.0
MAISHA_LLM_MAX_RETRIES=2

# --- Scheduler (daily CFO brief + snapshot capture) ---
MAISHA_BRIEF_HOUR=20
MAISHA_BRIEF_MINUTE=0
MAISHA_BRIEF_TZ=Asia/Kolkata
